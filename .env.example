# =====================================================================
# Expressia (codinome meu-jarvis) — variáveis de ambiente
# =====================================================================
# Copia este ficheiro para `.env.local` na raiz e preenche os valores
# reais. NÃO faças commit do `.env.local` — está no .gitignore.
# =====================================================================

# --------------------------------------------
# Base de dados (Supabase, eu-central-1)
# --------------------------------------------
# Connection string do Supabase Pooler em transaction-mode (porta 6543).
# Usada por Vercel serverless / Next.js runtime.
DATABASE_URL=

# Connection string directa (porta 5432) — usada apenas para migrations
# (drizzle-kit migrate) e scripts que precisam de transações longas.
DATABASE_URL_DIRECT=

# Connection string `service_role` / RLS-bypass para jobs sistémicos
# (cron Inngest: generate-recurring-tasks, cleanup-expired-reverse-ops, GDPR
# purge; scripts admin). Conecta como role `postgres` (table owner) e ignora
# RLS — confirmado: nenhuma migration usa FORCE para o owner e os triggers de
# imutabilidade só bloqueiam `authenticated`/`anon`. Consumida por
# `getServiceDb()` em `packages/db/src/client.ts`. Tipicamente IGUAL ao
# DATABASE_URL_DIRECT (porta 5432, session pooler). Sem esta variável, os
# jobs Inngest falham em runtime — não é apanhado pelos quality gates locais
# (testes mockam o db-shim).
DATABASE_URL_SERVICE_ROLE=

# URL pública do projecto Supabase (formato https://xxxx.supabase.co).
NEXT_PUBLIC_SUPABASE_URL=

# Anon key (pública) — RLS aplicada via JWT do utilizador autenticado.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — IGNORA RLS. Nunca exposta ao cliente.
SUPABASE_SERVICE_ROLE_KEY=

# --------------------------------------------
# Provedores de IA
# --------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --------------------------------------------
# Pagamentos (Stripe)
# --------------------------------------------
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --------------------------------------------
# Email transaccional (Resend, EU)
# --------------------------------------------
RESEND_API_KEY=

# --------------------------------------------
# Observabilidade (Sentry, UE region)
# --------------------------------------------
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --------------------------------------------
# Background jobs (Inngest, EU)
# --------------------------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --------------------------------------------
# Cache (Upstash Redis, EU)
# --------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --------------------------------------------
# Redirect de autenticação (SEC-9)
# --------------------------------------------
# Origin de confiança usado para construir os links de confirmação de email e
# de reset de palavra-passe (`{SITE_URL}/callback`). Quando definida, a app
# IGNORA os headers HTTP (`Host`/`Origin`) ao derivar o redirect — fecha o
# vector de password-reset-poisoning (header poisoning).
#
# Formato: URL absoluto SEM barra final, ex.: https://expressia.pt
# OBRIGATÓRIA em produção (Vercel Production) antes de tráfego real. Em
# desenvolvimento local / previews Vercel pode ficar vazia: a app cai no
# fallback por headers (localhost / *.vercel.app dinâmico).
SITE_URL=

# --------------------------------------------
# Runtime
# --------------------------------------------
NODE_ENV=development
