# =====================================================================
# Expressia (codinome meu-jarvis) — variáveis de ambiente
# =====================================================================
# Copia este ficheiro para `.env.local` na raiz e preenche os valores
# reais. NÃO faças commit do `.env.local` — está no .gitignore.
# =====================================================================

# --------------------------------------------
# Base de dados (Supabase, eu-central-1)
# --------------------------------------------
# Connection string do Supabase Pooler em transaction-mode (porta 6543).
# Usada por Vercel serverless / Next.js runtime.
DATABASE_URL=

# Connection string directa (porta 5432) — usada apenas para migrations
# (drizzle-kit migrate) e scripts que precisam de transações longas.
DATABASE_URL_DIRECT=

# Connection string `service_role` / RLS-bypass para jobs sistémicos
# (cron Inngest: generate-recurring-tasks, cleanup-expired-reverse-ops, GDPR
# purge; scripts admin). Conecta como role `postgres` (table owner) e ignora
# RLS — confirmado: nenhuma migration usa FORCE para o owner e os triggers de
# imutabilidade só bloqueiam `authenticated`/`anon`. Consumida por
# `getServiceDb()` em `packages/db/src/client.ts`. Tipicamente IGUAL ao
# DATABASE_URL_DIRECT (porta 5432, session pooler). Sem esta variável, os
# jobs Inngest falham em runtime — não é apanhado pelos quality gates locais
# (testes mockam o db-shim).
DATABASE_URL_SERVICE_ROLE=

# URL pública do projecto Supabase (formato https://xxxx.supabase.co).
NEXT_PUBLIC_SUPABASE_URL=

# Anon key (pública) — RLS aplicada via JWT do utilizador autenticado.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — IGNORA RLS. Nunca exposta ao cliente.
SUPABASE_SERVICE_ROLE_KEY=

# --------------------------------------------
# Provedores de IA
# --------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --------------------------------------------
# Pagamentos (Stripe)
# --------------------------------------------
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --------------------------------------------
# Email transaccional (Resend, EU)
# --------------------------------------------
RESEND_API_KEY=

# --------------------------------------------
# Observabilidade (Sentry, UE region)
# --------------------------------------------
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --------------------------------------------
# Background jobs (Inngest, EU)
# --------------------------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --------------------------------------------
# Cache (Upstash Redis, EU)
# --------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --------------------------------------------
# Redirect de autenticação (SEC-9)
# --------------------------------------------
# Origin de confiança usado para construir os links de confirmação de email e
# de reset de palavra-passe (`{SITE_URL}/callback`). Quando definida, a app
# IGNORA os headers HTTP (`Host`/`Origin`) ao derivar o redirect — fecha o
# vector de password-reset-poisoning (header poisoning).
#
# Formato: URL absoluto SEM barra final, ex.: https://expressia.pt
# OBRIGATÓRIA em produção (Vercel Production) antes de tráfego real. Em
# desenvolvimento local / previews Vercel pode ficar vazia: a app cai no
# fallback por headers (localhost / *.vercel.app dinâmico).
SITE_URL=

# --------------------------------------------
# Auditoria operacional (SEC-11)
# --------------------------------------------
# Estas duas variáveis são EXCLUSIVAMENTE para correr o `pnpm check:allowlist`
# localmente (auditoria da allowlist de Redirect URLs via Supabase Management
# API). NÃO são env vars de runtime de produção — não as definir na Vercel.
# O operador (Eurico/@devops) define-as no seu `.env.local` quando precisa de
# auditar a configuração. Modo gracioso: sem SUPABASE_ACCESS_TOKEN o script
# avisa e termina com exit 0 (não bloqueia CI).
#
# Personal Access Token Supabase — apenas para check:allowlist operacional, NÃO
# é var de runtime Vercel. Gerar em:
#   https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# Ref do projecto Supabase — apenas para check:allowlist operacional. É o
# identificador na URL do Dashboard (https://supabase.com/dashboard/project/<ref>).
SUPABASE_PROJECT_REF=

# --------------------------------------------
# Telegram Bot (J-1)
# --------------------------------------------
# Canal Telegram do Jarvis. As três variáveis vivem EXCLUSIVAMENTE em env vars
# da Vercel (ambiente Production, região UE) — nunca hardcoded, nunca em git.
# Em J-1 provam a tubagem do webhook (echo seguro); J-2 em diante liga o motor.
#
# Token do bot, obtido via @BotFather no Telegram. Formato `<id>:<segredo>`.
# Obrigatório em produção. NÃO commitar o valor real.
TELEGRAM_BOT_TOKEN=
#
# Secret aleatório configurado no `setWebhook` (campo `secret_token`) e enviado
# pelo Telegram no cabeçalho `X-Telegram-Bot-Api-Secret-Token`. O webhook
# rejeita (401) qualquer pedido sem este segredo correcto. Gerar com
# `openssl rand -hex 32`. Restrições da Bot API: só letras, dígitos e `_`,
# máx. 256 caracteres. Obrigatório em produção.
TELEGRAM_WEBHOOK_SECRET=
#
# [OBSOLETO desde J-2] `chat_id` do Telegram do Eurico — era a allowlist de
# identidade em J-1. A partir de J-2 a identidade resolve-se via a tabela
# `telegram_link` (chat_id → user_id + household_id), lida no webhook com
# getServiceDb(). Esta variável já NÃO é usada pelo código para autorização e
# pode ser removida das env vars da Vercel. Mantida aqui apenas como nota de
# migração. Obter o chat_id via @userinfobot ou `getUpdates` (continua útil para
# o seed da telegram_link).
TELEGRAM_ALLOWED_CHAT_ID=

# --------------------------------------------
# Runtime
# --------------------------------------------
NODE_ENV=development
