{
  "name": "@meu-jarvis/db",
  "version": "0.1.0",
  "private": true,
  "description": "Database schema, Drizzle ORM client e migrações para o meu-jarvis (Expressia). PT-PT, Postgres 16+ Supabase eu-central-1.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts",
    "./types": "./src/types.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:check-rls": "tsx ../../scripts/check-rls-coverage.ts",
    "lint": "echo \"@meu-jarvis/db: lint herdado do typecheck Drizzle/TS — ver typecheck script\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "echo \"@meu-jarvis/db: package source-only (sem build step)\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "drizzle-orm": "^0.34.0",
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "drizzle-kit": "^0.25.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "engines": {
    "node": ">=20"
  }
}
