# =====================================================================
# apps/web/.env.example — variáveis de runtime do Next.js (apps/web)
# =====================================================================
# O ficheiro canónico completo é o `.env.example` na raiz do repo. Este espelho
# documenta as variáveis lidas directamente pelo app web. NUNCA commitar valores
# reais — tudo vive em Vercel Env (Production + Preview, região UE).

# --------------------------------------------
# Supabase
# --------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Postgres (dual-URL pooler Supabase — ver runbook supabase-setup.md)
DATABASE_URL=
DIRECT_URL=

# URL público do site (SEC-9) — usado para redirects de auth e para derivar o
# redirect_uri OAuth do Google. Sem barra final. Ex.: https://expressia.pt
SITE_URL=

# --------------------------------------------
# Google Calendar OAuth (J-3)
# --------------------------------------------
# Integração readonly do Google Calendar. Ver `.env.example` da raiz para
# instruções completas. NÃO commitar valores reais.
#
# Client ID OAuth 2.0 (Google Cloud Console — Web application).
GOOGLE_OAUTH_CLIENT_ID=
#
# Client secret OAuth 2.0 do mesmo projecto.
GOOGLE_OAUTH_CLIENT_SECRET=
#
# Chave AES-256-GCM (32 bytes, hex 64 chars OU base64) para cifrar o
# refresh_token OAuth. Gerar com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OAUTH_TOKEN_ENCRYPTION_KEY=
